-- Dual

case Dual Int

case Dual (Int -> (Char, String) -> [Float])

case Int -> (Char, Dual String) -> [Float]

-- Haskell Curry's paradoxical combinator Y. Can't possible be well formed; just
-- look at the part (x x).

case Y
where
  type G : (*T -> *T) -> (*T -> *T) -> *T
  type G f x = f (x x)
  type Y : (*T -> *T) -> *T
  type Y f = (G f) (G f)

-- Higher-order recursion

-- Perfect binary trees (nested datatypes). As in "System F-omega with
-- Equirecursive Types for Datatype-Generic Programming", Yufei Cai, Paolo G.
-- Giarrusso, Klaus Ostermann

case Tree
where
  type Tree : (*T -> *T) -> *T
  data Tree a = One a | Two Tree (a, a)
