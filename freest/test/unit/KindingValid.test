where
  type Stream : 1S -> 1S
  type Stream a = ?a ; Stream a

-- Poly Streams

case OutStream
where
  type OutStream : 1S
  type OutStream = exists a:*T . !a ; OutStream

case InStream
where
  type InStream : 1S
  type InStream = forall a:*T . ?a ; InStream

-- Same, with a function to consume the values

case PolyStream Bool
where
  type PolyStream : 1T -> 1S
  type PolyStream b = forall a:*T . ?(a -> b) ; ?a ; PolyStream b
  type Bool : 1T
  data Bool = False | True

-- Dual of the above

case PolyStream Bool
where
  type PolyStream : 1T -> 1S
  type PolyStream b = exists a:*T . !(a -> b) ; !a ; PolyStream b
  type Bool : 1T
  data Bool = False | True

-- Noncontractive types are the big new valid types

