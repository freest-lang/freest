--Session types generated by Quick Check

case forall a:1S . forall b:1S . forall z:1S . &{B: (&{C: A_8 b z};((Z_13 a ;B_14);?Int)), C: (?Char;((B_15 a z;Skip);+{A: (?Int;(&{B: Skip};(b;Skip)))}))} : 1T
where
  type A_8 : 1S -> 1S -> 1S
  type A_8 b z = A_9 b z
  type A_9 : 1S -> 1S -> 1S
  type A_9 b z = ((+{A: b, C: z};?Int);+{B: Skip, C: X});+{A: A_10, C: (Skip;Skip)}
  type X : 1S
  type X = ?Int
  type A_10 : 1S
  type A_10 = B_11
  type B_11 : 1S
  type B_11 = B_12
  type B_12 : 1S
  type B_12 = !()
  type Z_13 : 1S -> 1S
  type Z_13 a = +{B: ((Skip;(Skip;(Skip;(a;?Int))));(?Int;(Skip;!())))}
  type B_14 : 1S
  type B_14 = !()
  type B_15 : 1S -> 1S -> 1S
  type B_15 a z = (Skip;((Skip;z);((B_15 a z;(a;a));(Skip;(Skip;!())))))

case forall a: 1S . forall b: 1S . forall z: 1S . (Z a ;((a;&{B: (!Int;(?();b)), C: (Skip;(?();b))});((?Int;+{B: a, C: ?Int});!Int))) : 1T
where
  type Z : 1S -> 1S
  type Z a = Skip;&{B: (+{A: (&{B: a, C: Skip};+{A: (?Int;Skip), B: (Z a ;Skip), C: (((?Int;&{A: ((((?();a); Z a);+{A: Z a, C: Skip});!Int), C: !Char});Z a);Skip)})};(+{A: !Char};(((?Int;&{A: ((((?();a);Z a);+{A: Z a, C: Skip});!Int), C: !Char}); Z a);(?Char;((?Int;&{A: ((((?();a);Z a);+{A: Z a, C: Skip});!Int), C: !Char});Z a))))), C: Skip}

case forall a: 1S . forall b: 1S . forall z: 1S . B1 : 1T
where
  type B1 : 1S
  type B1 = +{A: (B1;&{A: (Skip;A1), C: (B1;A2)}), B: (Skip;&{A: (Skip;A3), C: (B1;A4)}), C: (!Int;&{A: (Skip;A5), C: (B1;A6)})}
  type A1 : 1S
  type A1 = +{A: (B1;&{A: (Skip;A1), C:(B1;A1)}), B: (Skip;&{A: (Skip;A1), C: (B1;A1)}), C: (!Int;&{A: (Skip;A1),C: (B1;A1)})}
  type A2 : 1S
  type A2 = +{A: (B1;&{A: (Skip;A2), C: (B1;A2)}), B:(Skip;&{A: (Skip;A2), C: (B1;A2)}), C: (!Int;&{A: (Skip;A2), C:(B1;A2)})}
  type A3 : 1S
  type A3 = +{A: (B1;&{A: (Skip;A3), C:(B1;A3)}), B: (Skip;&{A: (Skip;A3), C: (B1;A3)}), C: (!Int;&{A: (Skip;A3),C: (B1;A3)})}
  type A4 : 1S
  type A4 = +{A: (B1;&{A: (Skip;A4), C: (B1;A4)}), B:(Skip;&{A: (Skip;A4), C: (B1;A4)}), C: (!Int;&{A: (Skip;A4), C:(B1;A4)})}
  type A5 : 1S
  type A5 = +{A: (B1;&{A: (Skip;A5), C:(B1;A5)}), B: (Skip;&{A: (Skip;A5), C: (B1;A5)}), C: (!Int;&{A: (Skip;A5),C: (B1;A5)})}
  type A6 : 1S
