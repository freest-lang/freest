-- Polymorphic streams

-- case PolyStream
-- where
--   type PolyStream : 1S
--   type PolyStream = forall a:*T . ?a ; PolyStream

-- Dual of the above

-- case PolyStream
-- where
--   type PolyStream : 1S
--   type PolyStream = exists a:*T . !a ; PolyStream

-- Same, with a function to consume the values

case PolyStream Bool
where
  type PolyStream : 1T -> 1S
  type PolyStream b = forall a:*T . ?(a -> b) ; ?a ; PolyStream b
  type Bool : 1T
  data Bool = False | True

-- Dual of the above

case PolyStream Bool
where
  type PolyStream : 1T -> 1S
  type PolyStream b = exists a:*T . !(a -> b) ; !a ; PolyStream b
  type Bool : 1T
  data Bool = False | True

-- Noncontractive types are the big new valid types

case B
where 
  type B : 1S
  type B = Skip;B;?Char

case Z
where 
  type Z : 1S
  type Z = +{A: Skip, C: Z} ; B
  type B : 1S
  type B = (Skip;B);?Char

case Z1
where
  type Z1 : 1S
  type Z1 = Z2
  type Z2 : 1S
  type Z2 = A
  type A : 1S
  type A = +{A: Skip, C: A} ; Z3
  type Z3 : 1S
  type Z3 = B
  type B : 1S
  type B = Skip;(Z3;?Bool)

  type Bool : *T
  data Bool = False | True

case A
where
  type A : 1S
  type A = (Skip;A);!Bool

  type Bool : *T
  data Bool = False | True

