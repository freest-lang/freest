-- "System F-omega with Equirecursive Types for Datatype-Generic Programming",
-- Yufei Cai, Paolo G. Giarrusso, Klaus Ostermann

case Term
where
  type Term : *T
  data Term = Lit Int | Abs String Term | Var [Char] | App Term Term
  type String : *T
  type String = [Char]

case EvalCtx
where
  type EvalCtx : *T
  data EvalCtx = LitC Int | AbsC String Term | VarC String | AppC EvalCtx Term
  type Term : *T
  data Term = Lit Int | Abs String Term | Var [Char] | App Term Term
  type String : *T
  type String = [Char]

case VarTerm String
where
  type VarTerm : *T -> *T
  data VarTerm t = LitV Int | AbsV String Term | VarV t | AppV Term Term
  type Term : *T
  data Term = Lit Int | Abs String Term | Var [Char] | App Term Term
  type String : *T
  type String = [Char]

case EvalCtx
where
  type TermBase : *T -> *T -> *T -> *T
  data TermBase r s t = Lit Int | Abs String s | Var r | App t s
  type TermF : *T -> *T
  type TermF t = TermBase String t t
  type Term : *T
  -- type Term = Mu TermF, where Mu is a fixed point combinator which we cannot
  -- write. Instead we expand the definition:
  type Term = TermBase String Term Term
  type EvalCtx : *T -> *T
  type EvalCtx t = TermBase String Term t
  type VarTerm : *T -> *T
  type VarTerm t = TermBase t Term Term
  type String : *T
  type String = [Char]

-- When there is (unreachable) life past noncontractive (rec) types

case U
where
  type U : 1S -> 1S -> 1S -> 1S -> 1S -> 1S
  type U a1 a2 a3 a4 a5 = a1 ; a3 ; (U a1 a2 a3 a4 a5)

case T
where
  type T : 1S
  type T = !T ; !Int

case T -- Diverges, !Int is unreachable
where
  type T : 1S
  type T = !Float ; T ; !Int

case T -- Diverges, !Int is unreachable
where
  type T : 1S
  type T = !Float ; T ; !Int

case T -- Diverges, !Int is unreachable
where
  type T : 1S -> 1S
  type T a1 = a1 ; T a1 ; !Int

case T -- Diverges, a2 is unreachable
where
  type T : 1S -> 1S -> 1S
  type T a1 a2 = a1 ; (T a1 a2) ; a2

case T
where
  type T : 1S -> 1S -> 1S -> 1S -> 1S -> 1S
  type T a1 a2 a3 a4 a5 = a1 ; a3 ; (T a1 a2 a3 a4 a5) ; a2 ; a4

