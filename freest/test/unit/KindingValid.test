-- Same, with a function to consume the values

case PolyStream Bool : 1S
where
  type PolyStream : 1T -> 1S
  type PolyStream b = forall a:*T . ?(a -> b) ; ?a ; PolyStream b
  type Bool : 1T
  data Bool = False | True

-- Dual of the above

case PolyStream Bool : 1S
where
  type PolyStream : 1T -> 1S
  type PolyStream b = exists a:*T . !(a -> b) ; !a ; PolyStream b
  type Bool : 1T
  data Bool = False | True

