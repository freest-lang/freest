case Convert Id : 1S -> 1S
where
  type Convert : (1S -> 1S) -> 1S -> 1S
  type Convert a b = a b
  type Id : 1S -> 1S
  type Id a = a

case Convert Id Wait : 1S
where
  type Convert : (1S -> 1S) -> 1S -> 1S
  type Convert a b = a b
  type Id : 1S -> 1S
  type Id a = a

case Convert Id (Tree Int) : 1S
where
  type Convert : (1S -> 1S) -> 1S -> 1S
  type Convert a b = a b
  type Id : 1S -> 1S
  type Id a = a
  type Tree : *T -> 1S
  type Tree a = +{Leaf: Skip, Node: !a ; Tree a ; !a}

