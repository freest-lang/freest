case T;!Int : 1S
where
  type T : 1S
  type T = +{A: !Int;T, B: Skip;Close;Skip}
  type U : 1S
  type U = +{A: !Int;U, B: Close;U}

case U
where
  type T : 1S
  type T = +{A: !Int;T, B: Skip;Close;Skip}
  type U : 1S
  type U = +{A: !Int;U, B: Close;U}

case T
where 
  type T : 1S
  type T = T'
  type T' : 1S
  type T' = +{A: !Int;T', B:Close;T}
  type U : 1S
  type U = U'
  type U' : 1S
  type U' = +{A: !Int;U', B:Close;U'}

case U
where 
  type T : 1S
  type T = T'
  type T' : 1S
  type T' = +{A: !Int;T', B:Close;T}
  type U : 1S
  type U = U'
  type U' : 1S
  type U' = +{A: !Int;U', B:Close;U'}

case T
where
  type T : 1S
  type T = &{N:!Int;!Int;T, L:Close};?Int
  type U : 1S
  type U = &{N:!Int;!Int;U, L:Skip};Close

case U
where
  type T : 1S
  type T = &{N:!Int;!Int;T, L:Close};?Int
  type U : 1S
  type U = &{N:!Int;!Int;U, L:Skip};Close

case T
where
  type T : 1S
  type T = !(T';!Int);?(T;!(Close);Close;?Int)
  type T' : 1S
  type T' = +{A: !Int;T', B: Skip;Close;Skip}
  type U : 1S
  type U = !U';Skip;?(U;Skip;!(Close);Close;U;!U)
  type U' : 1S
  type U' = +{A: !Int;U', B: Close;U'}

case U
where
  type T : 1S
  type T = !(T';!Int);?(T;!(Close);Close;?Int)
  type T' : 1S
  type T' = +{A: !Int;T', B: Skip;Close;Skip}
  type U : 1S
  type U = !U';Skip;?(U;Skip;!(Close);Close;U;!U)
  type U' : 1S
  type U' = +{A: !Int;U', B: Close;U'}

case !(!Int;Close) 

case !(!Int;Skip;Close;?Int) 

case forall a:1S. Close;a;!Int 

case forall b:1S. (Close;b);Skip

case forall a:1S. T a
where
  type T : 1S -> 1S
  type T a = !(T' a;!Int);?(T a;!(Close);Close)
  type T' : 1S -> 1S
  type T' a = +{A: !a;T' a, B: a;Close;a}
  type U : 1S -> 1S
  type U  b = !(U' b);Skip;?(U b;Skip;!(Close);Close;b;!b)
  type U' : 1S -> 1S
  type U' b = +{A: !b;U' b, B: b;Close;!(U' b)}

case forall b: 1S . U b
where
  type T : 1S -> 1S
  type T a = !(T' a;!Int);?(T a;!(Close);Close)
  type T' : 1S -> 1S
  type T' a = +{A: !a;T' a, B: a;Close;a}
  type U : 1S -> 1S
  type U  b = !(U' b);Skip;?(U b;Skip;!(Close);Close;b;!b)
  type U' : 1S -> 1S
  type U' b = +{A: !b;U' b, B: b;Close;!(U' b)}

