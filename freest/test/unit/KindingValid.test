-- Recursive types
case A : 1S
where 
  type A : 1S
  type A = ?Int

case A : 1S
where
  type A : 1S
  type A = (!Int; Skip; ?Int)

case Tree : 1S
where
  type Tree : 1S
  type Tree = &{Leaf: Skip, Node: ?Int;Tree;Tree}

case TreeChannel : 1S
where
  type TreeChannel : 1S
  type TreeChannel = +{Leaf: Skip, Node: !Int;TreeChannel;TreeChannel}

case forall a : 1S .  Alpha a : 1T
where
  type Alpha : 1S -> 1S
  type Alpha a = !Int; TreeChannel1 a
  type TreeChannel1 : 1S -> 1S
  type TreeChannel1 a = +{Leaf:Skip, Node:!Int; TreeChannel1 a; TreeChannel1 a};TreeChannel2 a
  type TreeChannel2 : 1S -> 1S
  type TreeChannel2 a = +{Leaf:Skip, Node:!Int;TreeChannel2 a;TreeChannel2 a};a

case forall a : 1S . Alpha a : 1T
where
  type Alpha : 1S -> 1S
  type Alpha a = !Int; TreeChannel1 a
  type TreeChannel1 : 1S -> 1S
  type TreeChannel1 a = +{Leaf:Skip, Node:!Int; TreeChannel1 a; TreeChannel1 a};TreeChannel2 a
  type TreeChannel2 : 1S -> 1S
  type TreeChannel2 a = +{Leaf:Skip, Node:!Int;TreeChannel2 a;TreeChannel2 a};a

case A : 1T
where 
  type A : *T
  type A = (A, Int)

case B : 1T
where
  type B : *T
  type B = (B, Int -> Char)

case A : 1T
where
  type A : 1T
  type A = A 1-> A

case forall b : 1S . b : 1T

case forall a : 1S . B a : 1T
where
  type B : 1S -> 1S
  type B a = a

case forall b : 1S . A b : 1T
where
  type A : 1S -> 1S
  type A b = b ; A b

case forall a : 1S . D a : 1T
where
  type D : 1S -> 1S
  type D a = C a
  type C : 1S -> 1S
  type C a = B a
  type B : 1S -> 1S
  type B a = a

case A : 1T
where
  type A : *T
  type A = (A,Int)

case A : *T 
where
  type A : *T
  type A = forall b : 1S . A

case forall y : 1S . +{C: X1};(y;(X2 y;Skip))
where
  type X1 : *S
  type X1 = Skip
  type X2 : 1S -> 1S
  type X2 y = y

case forall y : 1S . +{C: (Skip;((y;X1 (X2 y));Skip))} : 1S
where
  type X1 : 1S -> 1S
  type X1 y = X2 y
  type X2 : 1S -> 1S
  type X2 y = y


