case Z
where
  type Z : 1S
  type Z = Z'
  type Z' : 1S
  type Z' = Skip;A
  type A : 1S
  type A = Z''
  type Z'' : 1S
  type Z'' = &{B: Z'''}
  type Z''' : 1S
  type Z''' = A'
  type A' : 1S 
  type A' = Z''';(Skip;!Char)
  -- Expected kind *S for type Z'', but got kind 1S. (vv) Z'' seems 1S to me

case Z
where
  type Z : 1S
  type Z = A
  type A : 1S
  type A = &{B: Z'}
  type Z' : 1S
  type Z' = (Z';Skip);!Char
