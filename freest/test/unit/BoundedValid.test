-- Close 

case Close

case Close;!Int

case Close;!Int

case Close;?Int

case !Char;Close;!Int 

case !Char;Close;?Int

case (!Int;Close;!Int);?Int 

case !Int;Close;!Int

case T;!Int
where
  type T : 1S
  type T = +{A: !Int;T, B: Skip;Close;Skip}
  type U : 1S
  type U = +{A: !Int;U, B: Close;U}

case U
where
  type T : 1S
  type T = +{A: !Int;T, B: Skip;Close;Skip}
  type U : 1S
  type U = +{A: !Int;U, B: Close;U}

case T
where 
  type T : 1S
  type T = T'
  type T' : 1S
  type T' = +{A: !Int;T', B:Close;T}
  type U : 1S
  type U = U'
  type U' : 1S
  type U' = +{A: !Int;U', B:Close;U'}

case U
where 
  type T : 1S
  type T = T'
  type T' : 1S
  type T' = +{A: !Int;T', B:Close;T}
  type U : 1S
  type U = U'
  type U' : 1S
  type U' = +{A: !Int;U', B:Close;U'}

case T
where
  type T : 1S
  type T = &{N:!Int;!Int;T, L:Close};?Int
  type U : 1S
  type U = &{N:!Int;!Int;U, L:Skip};Close

case U
where
  type T : 1S
  type T = &{N:!Int;!Int;T, L:Close};?Int
  type U : 1S
  type U = &{N:!Int;!Int;U, L:Skip};Close

case forall a:1S. Close;a;!Int 

case forall b:1S. (Close;b);Skip

