-- Type applications

case Int Int

case T Int Char
where
  type T : *T -> *T
  type T a = a

case T Int
where
  type T : 1S -> 1S
  type T a = a

-- Dual related types

case Dual Int

case Dual (Int -> (Char, String) -> [Float])

case Int -> (Char, Dual String) -> [Float]

-- Haskell Curry's paradoxical combinator Y. Can't possible be well formed; just
-- look at the part (x x).

case Y
where
  type G : (*T -> *T) -> (*T -> *T) -> *T
  type G f x = f (x x)
  type Y : (*T -> *T) -> *T
  type Y f = (G f) (G f)

-- (Non) Channel types

case T : 1C -> 1C
where
  type T : 1C -> 1C
  type T a = +{Done: Skip, More: !Int ; T a}

-- Type-level abstractions

case \(a : *T) -> b

case (\(a : *T) -> a) !Int

case (\(a : *T -> *T) -> a Int) Int

case (\(a : 1T) (b : *T) -> a) Int !Int

case (\(a : 1T) (b : *T) -> b) Int !Int

case (\(a : *T) -> !Int; a)

case 
  \(f : *T -> *T) -> 
    ((\(f : *T -> *T) (x : *T -> *T) -> f (x x)) f) 
    ((\(f : *T -> *T) (x : *T -> *T) -> f (x x)) f)

-- Polymorphic type recursion

case PerfectTree : 1T -> 1S
where
  type PerfectTree : 1T -> 1S
  type PerfectTree a = +{Leaf: !a, Node: PerfectTree (a, a)}

case NestedTree : 1T -> 1S
where
  type NestedTree : 1T -> 1S
  type NestedTree a = +{Leaf: !a, Node: NestedTree [a]}

case A : 1T -> 1S
where
  type A : 1T -> 1S
  type A a = A Int

case A : 1T -> 1S
where
  type A, B : 1T -> 1S
  type A a = B a
  type B b = A Int

case A : 1T -> 1S
where
  type A : 1T -> 1S
  type A a = A a ; A Int

case A : 1T -> 1S
where
  type A, B : 1T -> 1S
  type A a = B a
  type B b = A b ; A Int

case A : 1T -> 1S
where
  type A, B : 1T -> 1S
  type A a = B a
  type B b = B b ; A Int

case A : 1T -> 1S
where
  type A, B : 1T -> 1S
  type A a = B a
  type B b = B Int

case A : 1T -> 1S
where
  type A, B : 1T -> 1S
  type A a = B Char
  type B b = A Int

case A : 1T -> 1S
where
  type A, B : 1T -> 1S
  type A a = B a ; A Int
  type B b = B b

case NestedTree : 1T -> 1S
where
  type NestedTree, A : 1T -> 1S
  type NestedTree a = +{Leaf: !a, Node: A [a]}
  type A b = NestedTree b
