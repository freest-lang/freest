  type T = &{N:!Int;!Int;T, L:Close};?Int

-- Types with the Dual operator

case Dual Close : 1C

case Dual (Dual (Dual Wait)) : 1C

case Dual !Int : 1S

case Dual Skip : *S

case Dual (Skip ; Skip) : *S

case Dual T : *S
where
  type T : *S
  type T = Skip

case Dual T : *S
where
  type T : *S
  type T = Dual Skip

case !(Dual ?Int) ; Close : 1C

case Id : 1S -> 1S
where
  type Id : 1S -> 1S
  type Id a = a

case Id (Int -> Char -> (Int, Char)) : *T
where
  type Id : *T -> *T
  type Id a = a

case Convert : (*T -> *T) -> *T -> *T
where
  type Convert : (*T -> *T) -> *T -> *T
  type Convert a b = a b

case Convert Id : 1S -> 1S
where
  type Convert : (1S -> 1S) -> 1S -> 1S
  type Convert a b = a b
  type Id : 1S -> 1S
  type Id a = a

case ABStream Int : *T -> 1S
where
  type ABStream : *T -> *T -> 1S
  type ABStream a b = !a ; !b ; ABStream a b

case Id Wait : 1S
where
  type Id : 1S -> 1S
  type Id a = a

case Convert Id Wait : 1S
where
  type Convert : (1S -> 1S) -> 1S -> 1S
  type Convert a b = a b
  type Id : 1S -> 1S
  type Id a = a

case Convert Id Wait : 1C
where
  type Convert : (1C -> 1C) -> 1C -> 1C
  type Convert a b = a b
  type Id : 1C -> 1C
  type Id a = a

case Convert Id (Tree Int) : 1S
where
  type Convert : (1S -> 1S) -> 1S -> 1S
  type Convert a b = a b
  type Id : 1S -> 1S
  type Id a = a
  type Tree : *T -> 1S
  type Tree a = +{Leaf: Skip, Node: !a ; Tree a ; !a}

