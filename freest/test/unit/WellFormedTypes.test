case 
  (\(a : 1S -> 1S) (b : 1S) -> a b) 
    (\(a : 1S) -> a) 
    (Tree Int) 
  : 1S
where
  type Tree : *T -> 1S
  type Tree = \(a : *T) -> +{Leaf: Skip, Node: !a ; Tree a ; !a}

case Succ (Succ (\(s : *T -> *T) (z : *T) -> z)) : (*T -> *T) -> *T -> *T
where
  type Succ : ((*T -> *T) -> *T -> *T) -> ((*T -> *T) -> *T -> *T)
  type Succ = \(n : (*T -> *T) -> *T -> *T) (s : *T -> *T) (z : *T) -> s (n s z)

case 
    (\(n : (*T -> *T) -> *T -> *T) (s : *T -> *T) (z : *T) -> s (n s z)) 
      ((\(n : (*T -> *T) -> *T -> *T) (s : *T -> *T) (z : *T) -> s (n s z)) 
        (\(s : *T -> *T) (z : *T) -> z)) 
  : (*T -> *T) -> *T -> *T
