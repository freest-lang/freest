-- "System F-omega with Equirecursive Types for Datatype-Generic Programming",
-- Yufei Cai, Paolo G. Giarrusso, Klaus Ostermann

case Term : *T
where
  type Term : *T
  data Term = Lit Int | Abs String Term | Var [Char] | App Term Term
  type String : *T
  type String = [Char]

case EvalCtx : *T
where
  type EvalCtx : *T
  data EvalCtx = LitC Int | AbsC String Term | VarC String | AppC EvalCtx Term
  type Term : *T
  data Term = Lit Int | Abs String Term | Var [Char] | App Term Term
  type String : *T
  type String = [Char]

case VarTerm String : *T
where
  type VarTerm : *T -> *T
  data VarTerm t = LitV Int | AbsV String Term | VarV t | AppV Term Term
  type Term : *T
  data Term = Lit Int | Abs String Term | Var [Char] | App Term Term
  type String : *T
  type String = [Char]

case EvalCtx : *T -> *T
where
  type TermBase : *T -> *T -> *T -> *T
  data TermBase r s t = Lit Int | Abs String s | Var r | App t s
  type TermF : *T -> *T
  type TermF t = TermBase String t t
  type Term : *T
  -- type Term = Mu TermF, where Mu is a fixed point combinator which we cannot
  -- write. Instead we expand the definition:
  type Term = TermBase String Term Term
  type EvalCtx : *T -> *T
  type EvalCtx t = TermBase String Term t
  type VarTerm : *T -> *T
  type VarTerm t = TermBase t Term Term
  type String : *T
  type String = [Char]


-- When there is (unreachable) life past noncontractive (rec) types

case U : 1S -> 1S -> 1S -> 1S -> 1S -> 1S
where
  type U : 1S -> 1S -> 1S -> 1S -> 1S -> 1S
  type U a1 a2 a3 a4 a5 = a1 ; a3 ; (U a1 a2 a3 a4 a5)

case T : 1S
where
  type T : 1S
  type T = !T ; !Int

case T : 1C
where
  type T : 1C
  type T = !Float ; T ; !Int

case T : 1S -> 1C
where
  type T : 1S -> 1C
  type T a1 = a1 ; T a1 ; !Int

case T : 1S -> 1S -> 1S
where
  type T : 1S -> 1S -> 1S
  type T a1 a2 = a1 ; (T a1 a2) ; a2

case T : 1S -> 1S -> 1S -> 1S -> 1S -> 1C
where
  type T : 1S -> 1S -> 1S -> 1S -> 1S -> 1C
  type T a1 a2 a3 a4 a5 = a1 ; a3 ; (T a1 a2 a3 a4 a5) ; a2 ; a4

case Either !Int : 1S -> 1T
where
  type Either : 1S -> 1S -> 1T
  data Either a b = Left a | Right b

-- kind polymorphism, https://downloads.haskell.org/~ghc/9.12-latest/docs/users_guide/exts/poly_kinds.html

case App : (1T -> *T) -> 1T -> *T
where
  type App : (1T -> *T) -> 1T -> *T
  data App f a = MkApp (f a)

case App : ((1S -> 1S) -> *T) -> (1S -> 1S) -> *T
where
  type App : ((1S -> 1S) -> *T) -> (1S -> 1S) -> *T
  data App f a = MkApp (f a)

case App : (((1S -> *T) -> 1T) -> *T) -> ((1S -> *T) -> 1T) -> *T
where
  type App : (((1S -> *T) -> 1T) -> *T) -> ((1S -> *T) -> 1T) -> *T
  data App f a = MkApp (f a)

-- Polymorphic recursion, https://stackoverflow.com/questions/40247339/polymorphic-recursion-syntax-and-uses

case Nested : *T -> *T
where
  type Nested : *T -> *T
  data Nested a = NestedCons a (Nested [a]) | Epsilon

-- Perfect trees are symmetric and complete. They have exactly 2^n leaf values,
-- where n is the height of the tree.
-- https://www.cis.upenn.edu/~plclub/blog/2020-12-04-nested-datatypes/

case PTree : 1T -> 1T
where
  type PTree: 1T -> 1T
  data PTree a = Leaf a | Node (PTree (a, a))

-- Infra and Supra type application

case Infra Int : 1S -> 1S
where
  type Infra : *T -> 1S -> 1S
  type Infra a b = !b

case Supra Int Char : 1S
where
  type Supra : 1T -> 1T -> 1S
  type Supra a = A
  type A : 1T -> 1S
  type A b = !b

case Suupra Int Char : 1S -> 1S
where
  type Suupra : 1T -> 1T -> 1S -> 1S
  type Suupra a = A
  type A : 1T -> 1S -> 1S
  type A b c = !b

